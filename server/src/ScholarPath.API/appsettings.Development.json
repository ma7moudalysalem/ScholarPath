{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=ScholarPath_v2.db"
  },
  "DatabaseSettings": {
    "UseSqlite": true
  },
  "JwtSettings": {
    "SecretKey": "DevSecretKey-32CharactersMinimum-DoNotUseInProduction!!",
    "Issuer": "ScholarPath",
    "Audience": "ScholarPathApp",
    "AccessTokenExpirationMinutes": 30,
    "RefreshTokenExpirationDays": 3
  },
  "Redis": {
    "Enabled": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information",
        "System": "Information"
      }
    }
  },
  "ExternalAuth": {
    "Google": {
      "ClientId": "",
      "ClientSecret": ""
    },
    "Microsoft": {
      "ClientId": "",
      "ClientSecret": "",
      "TenantId": "common"
    }
  },
  "Hangfire": {
    "Enabled": false
  }
}
