{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=ScholarPathDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "DatabaseSettings": {
    "UseSqlite": false
  },
  "JwtSettings": {
    "SecretKey": "",
    "Issuer": "ScholarPath",
    "Audience": "ScholarPathApp",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "EmailSettings": {
    "SmtpHost": "smtp.example.com",
    "SmtpPort": 587,
    "SenderEmail": "noreply@scholarpath.com",
    "SenderName": "ScholarPath",
    "Password": "",
    "EnableSsl": true
  },
  "Redis": {
    "ConnectionString": "localhost:6379,password=devpassword",
    "Enabled": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/scholarpath-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000"
    ]
  },
  "Hangfire": {
    "Enabled": false
  },
  "AllowedHosts": "*"
}
