{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithThreadId", "WithEnvironmentName" ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/scholarpath-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=ScholarPath;User Id=sa;Password=YourStrong(!)Password;TrustServerCertificate=true;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Issuer": "https://scholarpath.local",
    "Audience": "https://scholarpath.local",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7,
    "RefreshTokenRememberMeExpirationDays": 30,
    "SigningKey": "PLACEHOLDER_JWT_DEV_SIGNING_KEY_AT_LEAST_64_CHARS_FOR_HMAC_SHA256_xxxxx"
  },
  "Authentication": {
    "Google": {
      "ClientId": "PLACEHOLDER_GOOGLE_CLIENT_ID",
      "ClientSecret": "PLACEHOLDER_GOOGLE_CLIENT_SECRET"
    },
    "Microsoft": {
      "ClientId": "PLACEHOLDER_MICROSOFT_CLIENT_ID",
      "ClientSecret": "PLACEHOLDER_MICROSOFT_CLIENT_SECRET"
    }
  },
  "Stripe": {
    "SecretKey": "PLACEHOLDER_STRIPE_SECRET_KEY",
    "PublishableKey": "PLACEHOLDER_STRIPE_PUBLISHABLE_KEY",
    "WebhookSecret": "PLACEHOLDER_STRIPE_WEBHOOK_SIGNING_SECRET",
    "ConnectClientId": "PLACEHOLDER_STRIPE_CONNECT_CLIENT_ID"
  },
  "Email": {
    "Provider": "MailKit",
    "From": "no-reply@scholarpath.local",
    "FromName": "ScholarPath",
    "MailKit": {
      "Host": "localhost",
      "Port": 1025,
      "Username": "",
      "Password": "",
      "UseSsl": false
    },
    "SendGrid": {
      "ApiKey": "PLACEHOLDER_SENDGRID_API_KEY"
    }
  },
  "Redis": {
    "Enabled": false,
    "ConnectionString": "localhost:6379"
  },
  "Hangfire": {
    "Enabled": false,
    "DashboardEnabled": true
  },
  "Storage": {
    "Provider": "Local",
    "Local": {
      "BasePath": "./uploads"
    },
    "AzureBlob": {
      "ConnectionString": "PLACEHOLDER_AZURE_BLOB_CONN",
      "ContainerName": "scholarpath-uploads"
    }
  },
  "Ai": {
    "Provider": "Stub",
    "OpenAi": {
      "ApiKey": "PLACEHOLDER_OPENAI_API_KEY",
      "Model": "gpt-4o-mini"
    },
    "AzureOpenAi": {
      "Endpoint": "PLACEHOLDER_AZURE_OPENAI_ENDPOINT",
      "ApiKey": "PLACEHOLDER_AZURE_OPENAI_API_KEY",
      "DeploymentName": "gpt-4o-mini"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  }
}
