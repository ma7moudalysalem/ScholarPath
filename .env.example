# ScholarPath — environment template
# Copy to .env and fill for local development. NEVER commit .env.

# ============================== Backend (ASP.NET Core 10) ==============================
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000

# SQL Server (matches docker-compose.yml)
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=ScholarPath;User Id=sa;Password=YourStrong(!)Password;TrustServerCertificate=true;MultipleActiveResultSets=true

# JWT
Jwt__Issuer=https://scholarpath.local
Jwt__Audience=https://scholarpath.local
Jwt__AccessTokenExpirationMinutes=60
Jwt__RefreshTokenExpirationDays=7
Jwt__RefreshTokenRememberMeExpirationDays=30
Jwt__RsaPublicKeyPath=./keys/jwt-public.pem
Jwt__RsaPrivateKeyPath=./keys/jwt-private.pem

# OAuth (placeholders — paste real client IDs/secrets into user-secrets, never here)
Authentication__Google__ClientId=PLACEHOLDER_GOOGLE_CLIENT_ID
Authentication__Google__ClientSecret=PLACEHOLDER_GOOGLE_CLIENT_SECRET
Authentication__Microsoft__ClientId=PLACEHOLDER_MICROSOFT_CLIENT_ID
Authentication__Microsoft__ClientSecret=PLACEHOLDER_MICROSOFT_CLIENT_SECRET

# Stripe (test-mode keys from dashboard; use test key sk_test_... only)
Stripe__SecretKey=PLACEHOLDER_STRIPE_SECRET_KEY
Stripe__PublishableKey=PLACEHOLDER_STRIPE_PUBLISHABLE_KEY
Stripe__WebhookSecret=PLACEHOLDER_STRIPE_WEBHOOK_SIGNING_SECRET
Stripe__ConnectClientId=PLACEHOLDER_STRIPE_CONNECT_CLIENT_ID

# Email (MailHog dev SMTP default; swap for SendGrid in prod)
Email__Provider=MailKit
Email__From=no-reply@scholarpath.local
Email__FromName=ScholarPath
Email__MailKit__Host=localhost
Email__MailKit__Port=1025
Email__MailKit__Username=
Email__MailKit__Password=
Email__SendGrid__ApiKey=PLACEHOLDER_SENDGRID_API_KEY

# Redis (feature-flagged off in dev)
Redis__Enabled=false
Redis__ConnectionString=localhost:6379

# Hangfire (feature-flagged off in dev)
Hangfire__Enabled=false
Hangfire__DashboardEnabled=true

# Blob storage (local FS in dev; Azure Blob in prod)
Storage__Provider=Local
Storage__Local__BasePath=./uploads
Storage__AzureBlob__ConnectionString=PLACEHOLDER_AZURE_BLOB_CONN
Storage__AzureBlob__ContainerName=scholarpath-uploads

# AI (stub provider returns canned responses by default)
Ai__Provider=Stub
Ai__OpenAi__ApiKey=PLACEHOLDER_OPENAI_API_KEY
Ai__OpenAi__Model=gpt-4o-mini
Ai__AzureOpenAi__Endpoint=PLACEHOLDER_AZURE_OPENAI_ENDPOINT
Ai__AzureOpenAi__ApiKey=PLACEHOLDER_AZURE_OPENAI_API_KEY
Ai__AzureOpenAi__DeploymentName=gpt-4o-mini

# Serilog
Serilog__MinimumLevel__Default=Information
Serilog__MinimumLevel__Override__Microsoft=Warning
Serilog__MinimumLevel__Override__Microsoft.Hosting.Lifetime=Information

# CORS
Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=http://localhost:3000

# ============================== Frontend (Vite) ==============================
VITE_API_BASE_URL=http://localhost:5000
VITE_APP_NAME=ScholarPath
VITE_APP_ENV=development
VITE_STRIPE_PUBLISHABLE_KEY=PLACEHOLDER_STRIPE_PUBLISHABLE_KEY
VITE_GOOGLE_CLIENT_ID=PLACEHOLDER_GOOGLE_CLIENT_ID
VITE_MICROSOFT_CLIENT_ID=PLACEHOLDER_MICROSOFT_CLIENT_ID
