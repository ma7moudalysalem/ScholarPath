# ─── Database ─────────────────────────────────────────────────────────────────
# .NET reads nested config via double underscores: ConnectionStrings__DefaultConnection
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=ScholarPathDb;User Id=sa;Password=Your_Strong_Password123;TrustServerCertificate=True

# ─── Docker (SQL Server + Redis) ─────────────────────────────────────────────
SA_PASSWORD=ScholarPath_Dev_123!
REDIS_PASSWORD=devpassword

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-256-bit-secret-key-here-change-in-production
JWT_ISSUER=ScholarPath
JWT_AUDIENCE=ScholarPathApp
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_CONNECTION=localhost:6379,password=devpassword

# ─── SMTP (Email) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@scholarpath.com
SMTP_FROM_NAME=ScholarPath

# ─── File Storage ────────────────────────────────────────────────────────────
STORAGE_PATH=./uploads

# ─── Development Settings ─────────────────────────────────────────────────────
DatabaseSettings__UseSqlite=true
Cors__AllowedOrigins__0=http://localhost:3000

# ─── Frontend URL (must match CORS AllowedOrigins config in appsettings.json) ─
FRONTEND_URL=http://localhost:3000
