' =====================================================================
'  ScholarPath — Per-subject-area EERD in Chen / Elmasri notation.
'  Notation (Elmasri & Navathe Fig. 3.14):
'     rectangle = entity      diamond = relationship
'     oval = attribute        underlined oval = key
'     double oval <<multi>>   = multivalued attribute
'     dashed oval <<derived>> = derived attribute
'     double line (=)         = TOTAL participation   (single line - = partial)
'     1 / N                   = cardinality ratio
'  All entities are STRONG (each owns a surrogate Id); existence dependence of
'  detail rows is shown by TOTAL participation, not by weak-entity boxes.
'  Coverage matches the live EF model (gap-analysis E3/E4/E5 closed): every
'  persistent entity in its subject area appears here.
' =====================================================================

@startchen EERD_Identity_Profile
entity USER {
  Id <<key>>
  Email
  AccountStatus
  ActiveRole
}
entity USER_PROFILE {
  Id <<key>>
  Gpa
  PreferredCountries <<multi>>
  ExpertiseTags <<multi>>
  CompanyAverageRating <<derived>>
  ProfileCompletenessPercent <<derived>>
}
entity ROLE {
  Id <<key>>
  Name
}
entity EDUCATION_ENTRY {
  Id <<key>>
  InstitutionName
  Degree
}
entity EXPERTISE_TAG {
  Id <<key>>
  Slug
  Category
}
entity REFRESH_TOKEN {
  Id <<key>>
  TokenHash
}
entity PASSWORD_RESET_TOKEN {
  Id <<key>>
  TokenHash
}
entity LOGIN_ATTEMPT {
  Id <<key>>
  Email
  Succeeded
}
entity UPGRADE_REQUEST {
  Id <<key>>
  Target
  Status
}
entity UPGRADE_REQUEST_FILE {
  Id <<key>>
  BlobUrl
}
entity UPGRADE_REQUEST_LINK {
  Id <<key>>
  Url
}
relationship HAS_PROFILE {
}
relationship HAS_ROLE {
}
relationship HAS_EDU {
}
relationship ISSUES {
}
relationship RESETS {
}
relationship ATTEMPTS {
}
relationship REQUESTS_UPG {
}
relationship HAS_FILE {
}
relationship HAS_LINK {
}
USER -1- HAS_PROFILE
HAS_PROFILE =1= USER_PROFILE
USER -N- HAS_ROLE
HAS_ROLE -N- ROLE
USER_PROFILE -1- HAS_EDU
HAS_EDU =N= EDUCATION_ENTRY
USER -1- ISSUES
ISSUES =N= REFRESH_TOKEN
USER -1- RESETS
RESETS =N= PASSWORD_RESET_TOKEN
USER -1- ATTEMPTS
ATTEMPTS -N- LOGIN_ATTEMPT
USER -1- REQUESTS_UPG
REQUESTS_UPG =N= UPGRADE_REQUEST
UPGRADE_REQUEST -1- HAS_FILE
HAS_FILE =N= UPGRADE_REQUEST_FILE
UPGRADE_REQUEST -1- HAS_LINK
HAS_LINK =N= UPGRADE_REQUEST_LINK
@endchen


