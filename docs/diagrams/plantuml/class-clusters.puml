' =====================================================================
'  ScholarPath — UML class diagrams, split per subject area.
'  Notation matches Section 9 (course UML deck): plain rectangle with THREE
'  rows (name / attributes / operations) -- "hide circle" drops PlantUML's
'  stereotype icon and empty members are kept so the three compartments always
'  show; member style "name : Type" with visibility - private + public
'  # protected; generalization = hollow triangle, aggregation = hollow diamond,
'  composition = filled diamond, association = line with multiplicities + roles.
'
'  Coverage matches the live EF model (gap-analysis C1-C7 closed):
'   * C1 — ApplicationUser inherits IdentityUser<Guid> + ISoftDeletable, NOT
'          AuditableEntity (so the per-figure "all classes : AuditableEntity"
'          caveat excludes it; see its stereotype).
'   * C5/C6 — every entity in the area is drawn, incl. token/child/lookup tables
'          and the UpgradeRequest children.
'   * C7 — derived members are shown with a leading '/'.
'  Base-type inheritance is shown ONCE in Class_Base_Types.
' =====================================================================

@startuml Class_Base_Types
title Base entity types (domain classes inherit AuditableEntity; USERS is the exception)
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam ranksep 55
hide circle
abstract class BaseEntity {
  -Id : Guid
  +DomainEvents : IReadOnlyCollection<DomainEvent>
  +RaiseDomainEvent(e) : void
  +ClearDomainEvents() : void
}
abstract class AuditableEntity {
  -CreatedAt : DateTimeOffset
  -CreatedByUserId : Guid?
  -UpdatedAt : DateTimeOffset?
  -UpdatedByUserId : Guid?
  -RowVersion : byte[]
}
interface ISoftDeletable {
  +IsDeleted : bool
  +DeletedAt : DateTimeOffset?
  +DeletedByUserId : Guid?
}
class DomainEvent <<record>>
class "IdentityUser<Guid>" as IdentityUser <<framework>>
class ApplicationUser <<identity>>
BaseEntity <|-- AuditableEntity
BaseEntity ..> DomainEvent : raises
IdentityUser <|-- ApplicationUser
ApplicationUser ..|> ISoftDeletable
note bottom of ApplicationUser
  ApplicationUser does NOT inherit AuditableEntity.
  It extends IdentityUser<Guid>, implements ISoftDeletable,
  and carries a stripped audit triple (CreatedAt, UpdatedAt,
  RowVersion) -- no CreatedByUserId / UpdatedByUserId.
end note
@enduml


