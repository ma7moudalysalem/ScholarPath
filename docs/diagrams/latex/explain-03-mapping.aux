\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Relational mapping --- Identity, Access \& Profile. The \texttt  {Users}/\texttt  {UserProfiles} pair shows the single-table specialization (Step~8) plus the 1:1 link (Step~3); \texttt  {UserRoles} is the M:N junction (Step~5); \texttt  {Education\_Entries} is the cascading weak entity (Step~2).}}{8}{figure.caption.2}\protected@file@percent }
\newlabel{fig:identity}{{1}{8}{Relational mapping --- Identity, Access \& Profile. The \texttt {Users}/\texttt {UserProfiles} pair shows the single-table specialization (Step~8) plus the 1:1 link (Step~3); \texttt {UserRoles} is the M:N junction (Step~5); \texttt {Education\_Entries} is the cascading weak entity (Step~2)}{figure.caption.2}{}}
