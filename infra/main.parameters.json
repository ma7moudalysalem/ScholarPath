    "sqlAdminLogin": {
      "value": "scholarpathadmin"
    },
    "sqlDatabaseSku": {
      "value": "Basic"
    },
    "redisSkuName": {
      "value": "Basic"
    },
    "redisCapacity": {
      "value": 0
    },
    "jwtIssuer": {
      "value": "https://scholarpath-prod.example.com"
    },
    "jwtAudience": {
      "value": "https://scholarpath-prod.example.com"
    },
    "clientCorsOrigin": {
      "value": ""
    },
    "keyVaultAdminObjectId": {
      "value": ""
    }
  }
}
