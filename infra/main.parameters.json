{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "_comment": "Non-secret deployment parameters for infra/main.bicep. The one secret (sqlAdminPassword) is intentionally omitted — pass it on the az CLI command line or via a pipeline secret. The RS256 JWT signing key is not a Bicep parameter; the operator uploads it to Key Vault manually post-provision (see docs/deployment.md §5).",
  "parameters": {
    "baseName": {
      "value": "scholarpath"
    },
    "environmentName": {
      "value": "prod"
    },
    "appServicePlanSku": {
      "value": "B1"
    },
    "sqlAdminLogin": {
      "value": "scholarpathadmin"
    },
    "sqlDatabaseSku": {
      "value": "Basic"
    },
    "redisSkuName": {
      "value": "Basic"
    },
    "redisCapacity": {
      "value": 0
    },
    "jwtIssuer": {
      "value": "https://scholarpath-prod.example.com"
    },
    "jwtAudience": {
      "value": "https://scholarpath-prod.example.com"
    },
    "jwtKeyName": {
      "value": "scholarpath-jwt-signing"
    },
    "clientCorsOrigin": {
      "value": ""
    },
    "keyVaultAdminObjectId": {
      "value": ""
    }
  }
}
