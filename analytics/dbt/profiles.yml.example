# Copy to ~/.dbt/profiles.yml. Never commit the real file.
scholarpath:
  target: dev
  outputs:
    dev:
      type: sqlserver
      driver: "ODBC Driver 18 for SQL Server"
      server: "scholarpath-synapse-dev.sql.azuresynapse.net"
      port: 1433
      database: "warehouse"
      schema: "gold"
      authentication: ServicePrincipal
      tenant_id:   "{{ env_var('AZ_TENANT_ID') }}"
      client_id:   "{{ env_var('DBT_SP_CLIENT_ID') }}"
      client_secret: "{{ env_var('DBT_SP_CLIENT_SECRET') }}"
      encrypt: true
      trust_cert: false
      threads: 4

    ci:
      type: sqlserver
      driver: "ODBC Driver 18 for SQL Server"
      server: "{{ env_var('DBT_CI_SERVER') }}"
      database: "{{ env_var('DBT_CI_DB') }}"
      schema: "gold_ci"
      authentication: ActiveDirectoryPassword
      user: "{{ env_var('DBT_CI_USER') }}"
      password: "{{ env_var('DBT_CI_PASSWORD') }}"
      encrypt: true
      threads: 2
